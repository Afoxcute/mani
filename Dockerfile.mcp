# syntax=docker/dockerfile:1

FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /app

FROM base AS builder

# Copy only the workspace metadata and the packages needed by the MCP server.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages ./packages
COPY apps/mcp-server ./apps/mcp-server

RUN pnpm install --frozen-lockfile
RUN pnpm --filter '@x402/*' build && pnpm --filter mcp-server build

FROM base AS runner
ENV NODE_ENV=production
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages ./packages
COPY --from=builder /app/apps/mcp-server ./apps/mcp-server

EXPOSE 3001
ENV PORT=3001

# The entrypoint loads dotenv from apps/mcp-server, so keep the repo root as the working directory.
WORKDIR /app
CMD ["node", "apps/mcp-server/dist/index.js"]
