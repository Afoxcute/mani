{
  "name": "mani",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter web --filter mcp-server dev",
    "dev:web": "pnpm --filter web dev",
    "dev:mcp": "pnpm --filter mcp-server dev",
    "build": "pnpm build:packages && pnpm --filter web --filter mcp-server build",
    "build:packages": "pnpm --filter @x402/contracts build && pnpm --filter @x402/payment build",
    "build:web": "pnpm build:packages && pnpm --filter web build",
    "build:mcp": "pnpm build:packages && pnpm --filter mcp-server build",
    "start": "pnpm --parallel --filter web --filter mcp-server start",
    "start:web": "pnpm --filter web start",
    "start:mcp": "pnpm --filter mcp-server start",
    "lint": "pnpm --filter web lint",
    "type-check": "pnpm --filter web type-check"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.10.0+sha512.d615db246fe70f25dcfea6d8d73dee782ce23e2245e3c4f6f888249fb568149318637dca73c2c5c8ef2a4ca0d5657fb9567188bfab47f566d1ee6ce987815c39"
}
